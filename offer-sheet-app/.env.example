# Offer Sheet App Configuration

# Incoming Email Configuration (IMAP)
# This app uses a SEPARATE email from the main monitoring app
OFFER_SHEET_EMAIL=contractextraction@gmail.com
OFFER_SHEET_PASSWORD=your_email_password_here
OFFER_SHEET_HOST=imap.gmail.com
OFFER_SHEET_PORT=993

# Azure Email Configuration (SendGrid)
# Get your API key from Azure SendGrid service
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=contractextraction@gmail.com
SENDGRID_FROM_NAME=Arkansas Contract Agent - Offer Sheet

# OpenAI Configuration (for extraction)
OPENAI_API_KEY=your_openai_api_key_here

# Test Configuration (optional)
TEST_EMAIL_RECIPIENT=your_test_email@example.com